## Public (safe to expose to browser via Vite)
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

## Optional: Override ICE servers via JSON
# VITE_ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"}]'

## Server-only (DO NOT expose to browser)
## Use as Vercel Environment Variables or in .env.local (gitignored)
CLOUDFLARE_TURN_TOKEN_ID="your_token_id_here"
CLOUDFLARE_TURN_API_TOKEN="your_api_token_here"

